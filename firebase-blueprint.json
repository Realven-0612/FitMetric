{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile data",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "weight": { "type": "string" },
        "height": { "type": "string" },
        "bodyFat": { "type": "string" },
        "preferredStyle": { "type": "string" },
        "age": { "type": "string" },
        "level": { "type": "string" },
        "primaryGoal": { "type": "string" },
        "gender": { "type": "string" },
        "activityLevel": { "type": "string" },
        "createdAt": { "type": "string", "format": "timestamp" },
        "updatedAt": { "type": "string", "format": "timestamp" }
      },
      "required": ["userId"]
    },
    "Scan": {
      "title": "Scan",
      "description": "User physique scan history",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "image": { "type": "string" },
        "date": { "type": "string", "format": "timestamp" },
        "physiqueType": { "type": "string" },
        "bodyFatEstimate": { "type": "string" },
        "score": { "type": "number" },
        "muscleMass": { "type": "string" }
      },
      "required": ["userId"]
    },
    "WeightRecord": {
      "title": "Weight Record",
      "description": "User weight history",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "date": { "type": "string" },
        "value": { "type": "number" }
      },
      "required": ["userId", "date", "value"]
    },
    "FoodDiaryEntry": {
      "title": "Food Diary Entry",
      "description": "Daily food entries",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "date": { "type": "string" },
        "items": { "type": "array" },
        "updatedAt": { "type": "string", "format": "timestamp" }
      },
      "required": ["userId", "date"]
    },
    "DailyStats": {
      "title": "Daily Stats",
      "description": "Daily water and calories stats",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "date": { "type": "string" },
        "waterIntake": { "type": "number" },
        "consumedCalories": { "type": "number" },
        "updatedAt": { "type": "string", "format": "timestamp" }
      },
      "required": ["userId", "date"]
    },
    "StravaAuth": {
      "title": "Strava Auth Token",
      "description": "User Strava tokens",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "accessToken": { "type": "string" },
        "refreshToken": { "type": "string" },
        "expiresAt": { "type": "number" }
      },
      "required": ["userId"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "users/{userId}/scans/{scanId}": {
      "schema": "Scan",
      "description": "Physique scans for a user"
    },
    "users/{userId}/weightRecords/{recordId}": {
      "schema": "WeightRecord",
      "description": "Weight history matching dates"
    },
    "users/{userId}/foodDiary/{dateId}": {
      "schema": "FoodDiaryEntry",
      "description": "Daily food entries"
    },
    "users/{userId}/dailyStats/{dateId}": {
      "schema": "DailyStats",
      "description": "Daily stats like water and calories"
    },
    "users/{userId}/stravaAuth/{tokenId}": {
      "schema": "StravaAuth",
      "description": "Strava API tokens"
    }
  }
}
