# Force binary files to be treated as binary to prevent corruption during git push/pull
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary

# Handle line endings for text files
* text=auto eol=lf
*.ts text
*.tsx text
*.js text
*.jsx text
*.css text
*.html text
*.json text
*.md text
